generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  category    String
  material    String
  images      String   // JSON array of image URLs or placeholder logic
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}
